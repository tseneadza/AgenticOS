# ── Python ─────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
.ruff_cache/

# ── Runtime data / logs ────────────────────────────────
# state.db is retired — all run/checkpoint state now lives in MySQL. The
# entries below are kept only so any leftover local SQLite file (or its
# preserved .bak backup) from before the migration is never accidentally
# committed.
data/state.db
data/state.db.bak*
data/logs/

# ── Secrets / env ──────────────────────────────────────
.env
*.env
env.yaml

# ── Node / frontend (gui/desktop) ──────────────────────
node_modules/
gui/desktop/dist/

# ── Rust / Tauri build output ──────────────────────────
gui/desktop/src-tauri/target/

# ── Claude agent-farm scratch / state ──────────────────
.autoclaude/
.claude_agent_farm_backups/
.claude_agent_farm_state.json
.heartbeats/
agent_farm_reports/

# ── macOS ──────────────────────────────────────────────
.DS_Store
-e 
# SQLite WAL temp files
data/state.db-shm
data/state.db-wal
