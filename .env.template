# ─────────────────────────────────────────────────────
# AgenticOS Environment Variables Template
# ─────────────────────────────────────────────────────
# Copy this to .env.local and fill in your actual values.
# .env.local is in .gitignore and will NOT be committed.

# Database Configuration
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASS=your_mysql_password_here
MYSQL_DB=agenticos
MYSQL_PORT=3306

# API Keys (KEEP THESE SECRET - NEVER COMMIT TO GIT)
# Get your Anthropic API key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Token
# Get your GitHub token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here
