{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agentic OS",
  "version": "0.3.0",
  "identifier": "com.tonyseneadza.agenticos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agentic OS",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700
      },
      {
        "label": "hud",
        "title": "Agentic OS — HUD",
        "url": "index.html#/hud",
        "width": 250,
        "height": 520,
        "minWidth": 220,
        "minHeight": 240,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
